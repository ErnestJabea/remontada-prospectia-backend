NODE_ENV=development
PORT=3002

DB_HOST=localhost
DB_PORT=3306
DB_USER=crm_user
DB_PASSWORD=change-me
DB_NAME=nexus_crm

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace-with-another-32-character-secret
JWT_REFRESH_EXPIRES_IN=7d

ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
COOKIE_SECURE=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Remontada Prospectia <no-reply@example.com>"
SMTP_SECURE=false
SMTP_ALLOW_SELF_SIGNED=false

# Active uniquement si un OTP doit etre lu dans la console en developpement local.
LOG_DEV_OTP=false

SEED_ADMIN_PASSWORD=
SEED_DIRECTION_PASSWORD=
SEED_COMMERCIAL_JR_PASSWORD=
